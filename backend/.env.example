PORT=3000
NODE_ENV=development

# MySQL Cloud / local MySQL
DB_HOST=your_host
DB_PORT=your_port
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=your_db_name

# Set DB_SSL=true for many cloud providers. Use DB_SSL_REJECT_UNAUTHORIZED=false
# only when your provider uses a self-signed CA and you understand the tradeoff.
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN_SECONDS=604800
CORS_ORIGIN=*
