{
  "name": "productivity-management-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Node.js REST API for the Flutter Productivity Management app.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "migrate": "node scripts/run-sql.js database/schema.sql",
    "seed": "node scripts/run-sql.js database/seed.sql",
    "db:reset": "npm run migrate && npm run seed"
  },
  "dependencies": {
    "express": "^5.1.0",
    "mysql2": "^3.15.3",
    "nodemailer": "^7.0.10"
  }
}
